# Shared secret used to verify Happeo JWTs.
# Must match the value set in Happeo Admin → Custom Apps → your app → Shared Secret.
SHARED_SECRET=replace-with-your-shared-secret

# Set to "true" to skip JWT verification in local development.
# Never set this in production.
DEV_MODE=true

# Port the server listens on (default: 3001)
PORT=3001

# Comma-separated allowed CORS origins. Leave blank to allow all (local dev only).
# CORS_ORIGIN=https://your-happeo-domain.happeo.com

# Optional: URL of your real ITSM API. Swap getServices() in index.js to use it.
# ITSM_API_URL=https://your-company.service-now.com/api
